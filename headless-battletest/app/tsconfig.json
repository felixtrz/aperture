{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [
    "aperture.config.ts",
    "aperture.headless.config.ts",
    "aperture.shared-config.ts",
    "physics.headless.config.ts",
    "hier.headless.config.ts",
    "fx.headless.config.ts",
    "multi.headless.config.ts",
    "audio.headless.config.ts",
    "scale.headless.config.ts",
    "vite.config.ts",
    "src/**/*.ts",
    "phys-src/**/*.ts",
    "hier-src/**/*.ts",
    "fx-src/**/*.ts",
    "multi-src/**/*.ts",
    "audio-src/**/*.ts",
    "scale-src/**/*.ts",
    ".aperture/generated/**/*.d.ts"
  ]
}
