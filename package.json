{
  "name": "@aperture-engine/workspace",
  "version": "0.1.0",
  "description": "WebGPU-only, ECS-native 3D runtime where simulation is authoritative and rendering is a derived view.",
  "type": "module",
  "license": "MIT",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git"
  },
  "homepage": "https://github.com/felixtrz/aperture#readme",
  "bugs": "https://github.com/felixtrz/aperture/issues",
  "keywords": [
    "aperture",
    "game-engine",
    "webgpu",
    "ecs",
    "3d",
    "typescript"
  ],
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "tsc -b packages/simulation packages/physics packages/physics-rapier packages/render packages/runtime packages/webgpu packages/audio packages/vite-plugin packages/app packages/cli",
    "typecheck": "pnpm run build",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "check:doc-paths": "node scripts/check-doc-paths.mjs",
    "check:progress": "node scripts/check-progress-tracker.mjs && node scripts/check-plan-doc-status.mjs",
    "check:plan-docs": "node scripts/check-plan-doc-status.mjs",
    "check:publish": "node scripts/check-package-publish-readiness.mjs",
    "check:publish:pack": "node scripts/check-package-publish-readiness.mjs --pack",
    "check:release-config": "node scripts/check-release-config.mjs",
    "check:examples": "node --check scripts/serve-examples.mjs && node --check scripts/render-control.mjs && node --check scripts/check-example-control.mjs && node --check scripts/check-examples.mjs && node --check scripts/check-example-gallery.mjs && node scripts/check-example-control.mjs && node scripts/check-examples.mjs && node scripts/check-example-gallery.mjs",
    "check:deadcode": "knip --config knip.json --reporter compact --no-exit-code",
    "check:diagnostics": "node scripts/generate-diagnostics-catalog.mjs --check",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "agent:finalize": "node scripts/finalize-agent-status.mjs",
    "test:watch": "vitest",
    "test:shaders": "node scripts/webgpu-shader-compile-check.mjs",
    "test:tonemap-numeric": "node scripts/webgpu-tonemap-numeric-check.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chrome",
    "setup:references": "bash scripts/setup-references.sh",
    "audio:pcm-check": "node scripts/audio-pcm-check.mjs",
    "examples:build": "pnpm run build",
    "examples:serve": "node scripts/serve-examples.mjs",
    "render-control": "node scripts/render-control.mjs",
    "render-control:proofs": "node scripts/render-control.mjs proofs",
    "render-control:smoke-all": "node scripts/render-control.mjs smoke-all",
    "publish:dry-run": "pnpm run build && pnpm run check:publish:pack",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:dry-run": "pnpm run publish:dry-run",
    "release:publish": "pnpm run build && pnpm run check:publish:pack && changeset publish",
    "check": "pnpm run check:boundaries && pnpm run check:doc-paths && pnpm run check:progress && pnpm run check:release-config && pnpm run typecheck && pnpm run check:publish && pnpm run typecheck:test && pnpm run check:examples && pnpm run check:diagnostics && pnpm run lint && pnpm run format:check && pnpm test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@preact/signals-core": "^1.8.0",
    "elics": "^3.4.2",
    "wgpu-matrix": "^3.4.2"
  },
  "devDependencies": {
    "@aperture-engine/app": "workspace:*",
    "@aperture-engine/physics": "workspace:*",
    "@aperture-engine/physics-rapier": "workspace:*",
    "@aperture-engine/vite-plugin": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
