---
import "lumin/styles.css";
import "lumin/fonts.css";
import "../styles/docs.css";

interface Props {
  title: string;
  description: string;
  mainClass?: string;
}

const { title, description, mainClass = "" } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//u, "")}`;
const navItems = [
  ["Docs", "docs/"],
  ["Showcases", "showcases/"],
  ["Examples", "examples/"],
] as const;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase("aperture.svg")} />
  </head>
  <body class="docs-body">
    <header class="docs-topbar">
      <a class="docs-brand" href={base} aria-label="Aperture home">
        <img src={withBase("aperture.svg")} alt="" />
        <span>
          <strong>Aperture</strong>
          <small>3D engine for the agentic age.</small>
        </span>
      </a>
      <nav class="docs-nav" aria-label="Docs navigation">
        {
          navItems.map(([label, href]) => (
            <a href={withBase(href)}>{label}</a>
          ))
        }
        <a href="https://github.com/felixtrz/aperture">GitHub</a>
      </nav>
    </header>
    <main class:list={["docs-main", mainClass]}>
      <slot />
    </main>
  </body>
</html>
