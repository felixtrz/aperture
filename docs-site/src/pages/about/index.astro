---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { ReferenceSearch } from "../../components/ReferenceSearch";
import referenceAssetsPackage from "../../../../packages/reference-assets/package.json";
import { DEFAULT_LOCALE } from "../../i18n/locale.js";
import { getMessages } from "../../i18n/messages.js";

const m = getMessages(DEFAULT_LOCALE);

// Anchor ids and the non-translated index/status metadata stay here; the visible
// copy is sourced from the locale catalog so it can be swapped at runtime.
const factIds = [
  "ecs-source",
  "worker-runtime",
  "webgpu-renderer",
  "agent-tooling",
] as const;

const assumptionMeta = [
  { id: "solo-plus-agents", index: "01", status: "validated" },
  { id: "agent-native-tooling", index: "02", status: "open" },
  { id: "worker-default", index: "03", status: "open" },
  { id: "headless-agent-work", index: "04", status: "open" },
  { id: "ecosystem-moat", index: "05", status: "open" },
] as const;

const facts = m.about.facts.map((fact, index) => ({
  ...fact,
  id: factIds[index] ?? "",
}));

const assumptions = m.about.assumptions.map((assumption, index) => ({
  ...assumption,
  id: assumptionMeta[index]?.id ?? "",
  index: assumptionMeta[index]?.index ?? "",
  status: assumptionMeta[index]?.status ?? "open",
}));
---

<DocsLayout
  title="About Aperture"
  description="Aperture is a WebGPU-only, ECS-native 3D runtime for data-driven simulation, derived rendering, workers, and coding-agent workflows."
>
  <section class="about-section about-intro" aria-labelledby="what-it-is">
    <div class="about-section-head">
      <p class="docs-eyebrow" data-i18n="about.eyebrow">About</p>
      <h1 id="what-it-is" data-i18n="about.heading">What Aperture is.</h1>
      <p data-i18n="about.intro">
        Aperture is a WebGPU-only, ECS-native 3D runtime built around a simple
        architecture: ECS is authoritative, rendering is derived from
        snapshots, simulation can live in a worker, and coding agents are
        treated as first-class contributors. These are the concrete pieces that
        matter to the assumptions below.
      </p>
      <div class="about-cta-row">
        <div class="docs-command about-command">
          <span aria-hidden="true">$</span>
          <code>npx @aperture-engine/cli create my-app</code>
          <button
            class="about-copy-command"
            type="button"
            aria-label="Copy command"
            title="Copy command"
            data-i18n-attr="aria-label:about.copyCommand;title:about.copyCommand"
            data-command="npx @aperture-engine/cli create my-app"
          >
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              focusable="false"
            >
              <rect x="9" y="9" width="10" height="10" rx="2"></rect>
              <path d="M5 15V7a2 2 0 0 1 2-2h8"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="docs-section-grid about-fact-grid">
      {
        facts.map((fact, index) => (
          <article class="docs-panel about-fact-card" id={fact.id}>
            <div class="about-card-head">
              <h3 data-i18n={`about.facts.${index}.title`}>{fact.title}</h3>
              <span data-i18n={`about.facts.${index}.status`}>
                {fact.status}
              </span>
            </div>
            <p data-i18n={`about.facts.${index}.summary`}>{fact.summary}</p>
            <ul>
              {fact.points.map((point, pointIndex) => (
                <li data-i18n={`about.facts.${index}.points.${pointIndex}`}>
                  {point}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="about-section" aria-labelledby="assumptions">
    <div class="about-section-head">
      <p class="docs-eyebrow" data-i18n="about.assumptionsEyebrow">Assumptions</p>
      <h2 id="assumptions" data-i18n="about.assumptionsHeading">
        The bets being tested.
      </h2>
      <p data-i18n="about.assumptionsIntro">
        Aperture began as research, so these are intentionally short working
        hypotheses, not launch claims. Some of them may be wrong.
      </p>
    </div>

    <ol class="docs-section-grid assumption-list">
      {
        assumptions.map((assumption, index) => (
          <li class="docs-panel assumption-card" id={assumption.id}>
            <div class="about-card-head">
              <span class="assumption-index">{assumption.index}</span>
              <span
                class="assumption-status"
                data-status={assumption.status}
                data-i18n={`about.assumptions.${index}.statusLabel`}
              >
                {assumption.statusLabel}
              </span>
            </div>
            <h3 data-i18n={`about.assumptions.${index}.title`}>
              {assumption.title}
            </h3>
            <p data-i18n={`about.assumptions.${index}.summary`}>
              {assumption.summary}
            </p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="about-section about-search" aria-labelledby="search">
    <div class="about-section-head">
      <p class="docs-eyebrow" data-i18n="about.searchEyebrow">Search</p>
      <h2 id="search" data-i18n="about.searchHeading">
        Transformer-powered search.
      </h2>
      <p data-i18n="about.searchIntro">
        The reference index is part of the experiment: humans and agents can
        search the same generated docs, public APIs, examples, diagnostics, and
        curated source chunks.
      </p>
    </div>
    <ReferenceSearch
      assetsVersion={referenceAssetsPackage.version}
      client:load
    />
  </section>

  <script>
    const copyButtons = document.querySelectorAll<HTMLButtonElement>(
      "[data-command]",
    );

    for (const button of copyButtons) {
      button.addEventListener("click", async () => {
        const command = button.dataset.command;

        if (!command) {
          return;
        }

        try {
          await navigator.clipboard.writeText(command);
          button.dataset.copied = "true";
          button.setAttribute("aria-label", "Command copied");
          window.setTimeout(() => {
            button.dataset.copied = "false";
            button.setAttribute("aria-label", "Copy command");
          }, 1400);
        } catch {
          button.dataset.copied = "false";
        }
      });
    }
  </script>
</DocsLayout>
