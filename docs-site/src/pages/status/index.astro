---
import { access, readFile } from "node:fs/promises";
import path from "node:path";

const docsDir = path.join(process.cwd(), "..", "docs");
const statusPath = path.join(docsDir, "status", "index.html");
const legacyDashboardPath = path.join(docsDir, "index.html");

async function readable(file: string) {
  try {
    await access(file);
    return true;
  } catch {
    return false;
  }
}

const dashboardPath = (await readable(statusPath))
  ? statusPath
  : legacyDashboardPath;
const dashboardHtml = await readFile(dashboardPath, "utf8");
---

<Fragment set:html={dashboardHtml} />
