---
import DocsLayout from "../../layouts/DocsLayout.astro";

type AssumptionStatus = "validated" | "open" | "contested";

interface Assumption {
  id: string;
  index: string;
  title: string;
  statusLabel: string;
  status: AssumptionStatus;
  statement: string;
  detail: string;
}

const assumptions: Assumption[] = [
  {
    id: "solo-plus-agents",
    index: "01",
    title: "One developer + agents can build a full 3D engine",
    statusLabel: "Mostly validated",
    status: "validated",
    statement:
      "One person, working with agents, can now build a full-stack 3D engine foundation in about a month — not a triangle demo, but ECS, WebGPU rendering, physics, interaction, examples, tooling, and docs.",
    detail:
      "The claim is not that this is production-ready or on par with mature engines. It is that the minimum viable scope of what a single developer can attempt has changed. Aperture already has WebGPU rendering, ECS authoring, a worker/main split, physics, interaction, examples, showcase apps, CLI scaffolding, diagnostics, and agent-facing tooling.",
  },
  {
    id: "agent-native-tooling",
    index: "02",
    title: "Agent-native tooling can matter more than training-data familiarity",
    statusLabel: "Open hypothesis",
    status: "open",
    statement:
      "An engine designed from the start for agents — structured diagnostics, reference search, reproducible examples, inspectable runtime state, and agent-invocable tools — may eventually let agents work more effectively than in a larger engine designed primarily for humans.",
    detail:
      "Agents are very good with engines that dominate their training data, and for simple one-shot tasks that advantage is real today. The bet is that the picture changes for complex, iterative, debugging-heavy work, where queryable ECS state, deterministic stepping, and machine-readable diagnostics matter more than the number of prior examples.",
  },
  {
    id: "multithreaded-by-default",
    index: "03",
    title: "Web 3D engines should be multithreaded by default",
    statusLabel: "Active thesis",
    status: "open",
    statement:
      "App logic runs in a worker by default. The main thread owns the canvas, WebGPU presentation, and input; it does not own authoritative game state. Simulation produces structured render snapshots, and rendering consumes them.",
    detail:
      "This is both a performance bet and an agent-tooling bet. Freeing the main thread from simulation reduces jank; separating simulation from rendering by data makes it possible to step, diff, inspect, and reproduce behavior reliably. To my knowledge, Aperture is the first web 3D engine designed around worker-owned app logic by default.",
  },
  {
    id: "cloud-headless",
    index: "04",
    title: "Agentic 3D development moves toward cloud / headless workflows",
    statusLabel: "Open, compelling",
    status: "open",
    statement:
      "Coding agents increasingly run in the cloud, where GPU and browser access are expensive or unavailable. An engine for that world should let most development and validation happen headlessly, with visual rendering as a later, reproducible step.",
    detail:
      "Because Aperture's simulation layer does not require the browser, an agent can modify systems, run headless ECS steps, inspect entity state, and validate render snapshots in Node — and only invoke a GPU/browser renderer when it actually needs to see. Agents do most of the work in data, and render when they need to look.",
  },
  {
    id: "ecosystem-moat",
    index: "05",
    title: "The ecosystem moat weakens in the age of agents",
    statusLabel: "Open, contested",
    status: "contested",
    statement:
      "Today's dominant engines are dominant partly because of an enormous ecosystem. As agents get better at studying existing tools and synthesizing bespoke equivalents on demand, that moat may become less decisive.",
    detail:
      "The strong version is not \"ecosystems stop mattering.\" It is that their value may shift from reusable packages to reusable knowledge: if an agent can port the core idea of a library into a tailored implementation in minutes, ecosystem knowledge benefits everyone, not only the users of the original ecosystem. If the moat is permanent, a new engine has no chance; if it weakens, architecture gets to matter again.",
  },
];
---

<DocsLayout
  title="Aperture Research"
  description="Aperture is a personal research project exploring what a 3D engine looks like when it is designed for the agent era from the beginning. These are the assumptions it tests."
>
  <section class="docs-hero">
    <div>
      <p class="docs-eyebrow">Research</p>
      <h1>An engine built to test a few assumptions.</h1>
      <p>
        Aperture is a personal research project, not a production engine. It is a
        testbed for a question: what does a web 3D engine look like if it is
        designed for humans working with agents from the beginning — WebGPU-only,
        ECS-native, worker-first, and built around inspectable, agent-readable
        tooling? Five assumptions sit underneath it.
      </p>
    </div>
  </section>

  <ol class="docs-section-grid research-list" aria-label="Research assumptions">
    {
      assumptions.map((assumption) => (
        <li class="docs-panel research-card" id={assumption.id}>
          <div class="research-card-head">
            <span class="research-index">{assumption.index}</span>
            <span class="research-status" data-status={assumption.status}>
              {assumption.statusLabel}
            </span>
          </div>
          <h2>{assumption.title}</h2>
          <p class="research-statement">{assumption.statement}</p>
          <p class="research-detail">{assumption.detail}</p>
        </li>
      ))
    }
  </ol>

  <section class="docs-panel research-note" aria-label="Clarification">
    <h2>A clarification</h2>
    <p>
      Aperture is a personal research project — not a product launch, not
      production-ready, and not affiliated with my employer. It intentionally
      does not target WebXR; it exists to explore questions about WebGPU, ECS,
      worker-first architecture, and agent-native tooling. Treat everything here
      as a set of bets I am testing in the open, some of which may be wrong.
    </p>
  </section>
</DocsLayout>

<style>
  .research-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: none;
  }

  .research-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .research-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .research-index {
    font: 700 13px/1 var(--font-mono, ui-monospace, monospace);
    letter-spacing: 0.08em;
    color: var(--accent, #f7b955);
  }

  .research-status {
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.05);
    font: 650 11px/1 var(--font-mono, ui-monospace, monospace);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-muted, rgba(255, 255, 255, 0.72));
    white-space: nowrap;
  }

  .research-status[data-status="validated"] {
    border-color: rgba(120, 255, 190, 0.4);
    background: rgba(120, 255, 190, 0.12);
    color: #78ffbe;
  }

  .research-status[data-status="contested"] {
    border-color: rgba(247, 185, 85, 0.4);
    background: rgba(247, 185, 85, 0.12);
    color: var(--accent, #f7b955);
  }

  .research-card h2 {
    font-size: 20px;
    line-height: 1.25;
  }

  .research-statement {
    margin: 0;
    font-weight: 600;
  }

  .research-detail {
    margin: 0;
    color: var(--fg-muted, rgba(255, 255, 255, 0.72));
  }

  .research-note {
    margin-top: 18px;
  }

  .research-note h2 {
    font-size: 18px;
  }

  .research-note p {
    margin: 0;
    color: var(--fg-muted, rgba(255, 255, 255, 0.72));
  }
</style>
