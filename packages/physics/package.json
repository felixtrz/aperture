{
  "name": "@aperture-engine/physics",
  "version": "0.1.0",
  "description": "Backend-neutral physics components, fixed-step scheduling, and backend contracts for Aperture.",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git",
