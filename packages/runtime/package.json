{
  "name": "@aperture-engine/runtime",
  "version": "0.2.0",
  "description": "Headless simulation and render extraction runtime facade for Aperture.",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/felixtrz/aperture/tree/main/packages/runtime#readme",
  "bugs": "https://github.com/felixtrz/aperture/issues",
  "keywords": [
    "aperture",
    "ecs",
    "webgpu",
    "game-engine",
    "typescript",
    "runtime",
    "simulation"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aperture-engine/physics": "workspace:^",
    "@aperture-engine/render": "workspace:^",
    "@aperture-engine/simulation": "workspace:^"
  }
}
