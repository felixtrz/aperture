{
  "name": "@aperture-engine/particles",
  "version": "0.2.0",
  "description": "Particle authoring contracts and domain types for Aperture.",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git",
    "directory": "packages/particles"
  },
  "homepage": "https://github.com/felixtrz/aperture/tree/main/packages/particles#readme",
  "bugs": {
    "url": "https://github.com/felixtrz/aperture/issues"
  },
  "keywords": [
    "aperture",
    "particles",
    "ecs",
    "game-engine"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aperture-engine/simulation": "workspace:^"
  }
}
