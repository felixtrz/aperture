{
  "name": "@aperture-engine/cli",
  "version": "0.1.0",
  "description": "Aperture command-line tools for app creation, managed dev sessions, MCP, and reference tooling.",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/felixtrz/aperture/tree/main/packages/cli#readme",
  "bugs": "https://github.com/felixtrz/aperture/issues",
  "keywords": [
    "aperture",
    "cli",
    "scaffolding",
    "webgpu",
    "game-engine",
    "ecs",
    "typescript"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "bin": {
    "aperture": "./dist/bin/aperture.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "tar": "^7.5.15",
    "ts-morph": "^28.0.0",
    "vite": "^8.0.13"
  }
}
