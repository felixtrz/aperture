{
  "name": "@aperture-engine/audio",
  "version": "0.1.0",
  "description": "Main-thread Web Audio realization layer for Aperture: a derived view of the authoritative ECS simulation.",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git",
    "directory": "packages/audio"
  },
  "homepage": "https://github.com/felixtrz/aperture/tree/main/packages/audio#readme",
  "bugs": "https://github.com/felixtrz/aperture/issues",
  "keywords": [
    "aperture",
    "ecs",
    "game-engine",
    "typescript",
    "audio",
    "web-audio",
    "spatial-audio"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
