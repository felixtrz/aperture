{
  "name": "@aperture-engine/audio",
  "version": "0.1.0",
  "description": "Main-thread Web Audio realization layer for Aperture: a derived view of the authoritative ECS simulation.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-support": {
      "types": "./dist/test-support.d.ts",
      "import": "./dist/test-support.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aperture-engine/render": "workspace:^",
    "@aperture-engine/simulation": "workspace:^"
  }
}
