{
  "name": "@aperture-engine/math",
  "version": "0.2.0",
  "description": "Fast, zero-dependency, WebGPU-first 3D math for the Aperture engine: Float32Array-native vectors, quaternions, and matrices with fused transform fast paths.",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git",
    "directory": "packages/math"
  },
  "homepage": "https://github.com/felixtrz/aperture/tree/main/packages/math#readme",
  "bugs": "https://github.com/felixtrz/aperture/issues",
  "keywords": [
    "aperture",
    "webgpu",
    "3d-math",
    "matrix",
    "vector",
    "quaternion",
    "gamedev",
    "typescript",
    "linear-algebra"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "import": "./dist/kernel/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
