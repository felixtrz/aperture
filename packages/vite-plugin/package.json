{
  "name": "@aperture-engine/vite-plugin",
  "version": "0.1.0",
  "description": "Vite integration for Aperture config, worker system discovery, and generated browser bootstrap.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
