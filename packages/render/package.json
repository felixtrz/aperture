{
  "name": "@aperture-engine/render",
  "version": "0.2.0",
  "description": "Renderer-independent ECS authoring, assets, extraction, snapshots, and render-world contracts for Aperture.",
  "author": "Felix Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixtrz/aperture.git",
    "directory": "packages/render"
  },
  "homepage": "https://github.com/felixtrz/aperture/tree/main/packages/render#readme",
  "bugs": "https://github.com/felixtrz/aperture/issues",
  "keywords": [
    "aperture",
    "ecs",
    "webgpu",
    "game-engine",
    "typescript",
    "rendering",
    "gltf"
  ],
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-support": {
      "types": "./dist/test-support.d.ts",
      "import": "./dist/test-support.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aperture-engine/particles": "workspace:^",
    "@aperture-engine/simulation": "workspace:^"
  }
}
