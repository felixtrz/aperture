{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [
    "aperture.config.ts",
    "aperture.headless.config.ts",
    "aperture.shared-config.ts",
    "vite.config.ts",
    "src/**/*.ts",
    ".aperture/generated/**/*.d.ts"
  ]
}
